<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- 冷启动窗口主题：在 Flutter 首帧之前，用米色纸底 + 深色状态栏图标，
         避免通知栏出现白色/黑色闪一下的落差。 -->
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:statusBarColor">@color/ink_paper</item>
        <item name="android:navigationBarColor">@color/ink_paper</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">true</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@color/ink_paper</item>
        <item name="android:statusBarColor">@color/ink_paper</item>
        <item name="android:navigationBarColor">@color/ink_paper</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">true</item>
    </style>
</resources>
